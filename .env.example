# ===========================================
# AI Debate & Research Platform Configuration
# ===========================================

# ---- LLM Configuration --------------------
# For local LLMs (Ollama, LM Studio, etc.)
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=not-needed

# LLM model to use
LLM_MODEL=llama3

# For OpenAI (uncomment and set your key)
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini

# ---- Server Configuration ----------------
# Debate Simulator
FLASK_DEBUG=False
DEBATE_PORT=5050

# RAG Server
RAG_SERVER_URL=http://localhost:5080
RAG_PORT=5080

# ---- Paths ----------------------------------
# Character images directory
CHARACTER_IMAGES_DIR=images

# Data storage
STORAGE_DIR=storage

# ---- RAG Configuration ---------------------
# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS index
FAISS_INDEX_PATH=storage/faiss_db

# Document directories
DOC_DIR=doc
CODE_DIR=code

# ---- Logging --------------------------------
LOG_LEVEL=INFO
