# ===========================================
# AI Debate & Research Platform Configuration
# ===========================================

# ---- LLM Configuration --------------------
# FreeLLM API Server
OPENAI_API_BASE=https://api.freellmapi.com/v1
OPENAI_API_KEY=not-needed

# LLM model to use
LLM_MODEL=llama3

# ---- Server Configuration ----------------
FLASK_DEBUG=False
DEBATE_PORT=5050
RAG_SERVER_URL=http://localhost:5080
RAG_PORT=5080

# ---- Paths ----------------------------------
CHARACTER_IMAGES_DIR=images
STORAGE_DIR=storage

# ---- RAG Configuration ---------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=storage/faiss_db
DOC_DIR=doc
CODE_DIR=code

# ---- Logging --------------------------------
LOG_LEVEL=INFO
